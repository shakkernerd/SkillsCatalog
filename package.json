{
  "name": "skillcat",
  "version": "0.1.2",
  "description": "Curate and sync agent skills from multiple sources.",
  "keywords": [
    "agents",
    "codex",
    "skills",
    "cli",
    "catalog"
  ],
  "homepage": "https://github.com/shakkernerd/SkillsCatalog#readme",
  "bugs": {
    "url": "https://github.com/shakkernerd/SkillsCatalog/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shakkernerd/SkillsCatalog.git"
  },
  "license": "MIT",
  "author": "Shakker",
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "bin": {
    "skillcat": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "generate:version": "tsx scripts/generate-version.ts",
    "prebuild": "pnpm generate:version",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "skillcat": "node dist/cli.js",
    "start": "tsx src/cli.ts",
    "test": "vitest run test",
    "precheck": "pnpm generate:version",
    "check": "tsc -p tsconfig.json && vitest run test",
    "package:check": "node scripts/package-check.mjs --skip-version-check",
    "version:update": "node scripts/update-version.mjs",
    "release": "node scripts/release.mjs",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm check"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.13"
  }
}
